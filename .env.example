# Core
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# Database (Managed PostgreSQL in production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shoprex?schema=public

# Session/Auth
APP_SESSION_SECRET=change-me-super-secret-64-chars-minimum
APP_SESSION_COOKIE_NAME=shoprex_session
APP_SESSION_TTL_SECONDS=604800
ENABLE_DEV_AUTH_BYPASS=false
NEXTAUTH_SECRET=change-me-nextauth-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public frontend settings
NEXT_PUBLIC_WHATSAPP_NUMBER=237692714985
MINSHOP_AI_SERVICE_URL=http://127.0.0.1:8010
GEO_PROVIDER=MAPBOX
MAPBOX_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=

# Shopyia LLM (LangChain + Mistral)
MISTRAL_API_KEY=
# Keep "open-mistral-7b" for the requested Mistral 7B brain, or set another Mistral model if needed.
MISTRAL_MODEL=open-mistral-7b

# Payment default provider: MOCK | FLUTTERWAVE | CINETPAY
PAYMENT_DEFAULT_PROVIDER=FLUTTERWAVE

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

# CinetPay
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_WEBHOOK_SECRET=
